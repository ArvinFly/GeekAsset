<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <connectionStrings>
        <!-- 局域网部署时把 localhost 改为 SQL Server 所在内网服务器名/IP -->
        <add name="GeekAsset"
             connectionString="Server=localhost;Database=GeekAsset;Integrated Security=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
